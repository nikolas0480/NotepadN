{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sh",
          "cmd": "sh",
          "args": ["-c", { "validator": "\\S+" }]
        },
        {
          "name": "cmd",
          "cmd": "cmd",
          "args": ["/c", { "validator": "\\S+" }]
        }
      ]
    }
  ]
}
